{
  "name": "otplib-repo",
  "version": "12.0.1",
  "private": true,
  "type": "module",
  "description": "TypeScript-first library for TOTP and HOTP with multi-runtime and plugin support",
  "scripts": {
    "bench:base32": "pnpm --filter @repo/benchmarks bench:base32",
    "bench:hotp": "pnpm --filter @repo/benchmarks bench:hotp",
    "bench:totp": "pnpm --filter @repo/benchmarks bench:totp",
    "bench:utils": "pnpm --filter @repo/benchmarks bench:utils",
    "bench": "pnpm --filter @repo/benchmarks bench",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "docs:api": "turbo run docs:api",
    "docs:build": "turbo run docs:build",
    "docs:dev": "turbo run docs:dev",
    "docs:serve": "turbo run docs:serve",
    "fix": "pnpm lint:fix && pnpm format",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint:fix": "turbo run lint -- --fix",
    "lint": "turbo run lint",
    "postinstall": "lefthook install",
    "release:packages-dry-run": "pnpm publish -r --filter './packages/*' --access public --no-git-checks --dry-run",
    "release:packages": "pnpm publish -r --filter './packages/*' --access public --no-git-checks",
    "size:check": "node ./scripts/check-size.mjs --json",
    "size": "node ./scripts/check-size.mjs",
    "test:ci": "vitest --run --coverage",
    "test:dist-bun": "bun test internal/distribution-tests/src/bun.test.ts",
    "test:dist-deno": "deno test --allow-read --no-check internal/distribution-tests/src/deno.test.ts",
    "test:dist-node": "vitest run --config internal/distribution-tests/vitest.config.ts",
    "test:docker": "sh scripts/test-docker.sh",
    "test": "vitest --run",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@codecov/bundle-analyzer": "^1.9.1",
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.6.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vitest-tsconfig-paths": "^3.4.1"
  },
  "pnpm": {
    "overrides": {
      "ajv@>=6.0.0 <6.14.0": "6.14.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "markdown-it@>=13.0.0 <14.1.1": ">=14.1.1",
      "minimatch": ">=10.2.3",
      "preact@>=10.28.0 <10.28.2": ">=10.28.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "undici": ">=7.24.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
